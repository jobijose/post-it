# Copy this file to `.env` and fill in the values you need.
# All variables are prefixed with POSTIT_ and are optional unless you use the
# feature that requires them. `.env` is gitignored — never commit real secrets.

# ---- LLM provider selection ----
POSTIT_DEFAULT_PROVIDER=anthropic
POSTIT_DEFAULT_MODEL=claude-opus-4-8

# ---- LLM API keys (only the one for your provider is required) ----
POSTIT_ANTHROPIC_API_KEY=
POSTIT_OPENAI_API_KEY=

# ---- LinkedIn (only needed for the official-API publishing mode) ----
# Create a LinkedIn Developer app, request the "Share on LinkedIn" and
# "Sign In with LinkedIn using OpenID Connect" products, then run
# `post-it auth linkedin` to obtain the access token. See README.
POSTIT_LINKEDIN_CLIENT_ID=
POSTIT_LINKEDIN_CLIENT_SECRET=
POSTIT_LINKEDIN_ACCESS_TOKEN=
POSTIT_LINKEDIN_AUTHOR_URN=
# LinkedIn-Version header (YYYYMM). Bump periodically to a supported version.
POSTIT_LINKEDIN_API_VERSION=202505

# ---- Output ----
POSTIT_DRAFT_DIR=./drafts
